# ── Groq API ───────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Application ────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

# ── Database ───────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/claims.db

# ── LLM Model Config ──────────────────────────────────
VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
TEXT_MODEL=llama-3.3-70b-versatile

# ── File Uploads ───────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
